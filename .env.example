# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# Railway: use the DATABASE_URL from the PostgreSQL plugin dashboard.
# Local:   postgresql://user:password@localhost:5432/clinical_dss
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# ── Seeded admin credentials (used only on first boot) ────────────────────────
ADMIN_EMAIL=admin@clinic.local
ADMIN_PASSWORD=ChangeMe@2025
DOCTOR_EMAIL=doctor@clinic.local
DOCTOR_PASSWORD=ChangeMe@2025

# ── Runtime ───────────────────────────────────────────────────────────────────
FLASK_DEBUG=false
PORT=5000
